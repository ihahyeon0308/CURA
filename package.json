{
  "name": "cura-seoul-hospital-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter @cura/web dev",
    "dev:api": "pnpm --filter @cura/api start:dev",
    "build:web": "pnpm --filter @cura/web build",
    "build:api": "pnpm --filter @cura/api build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  }
}
